{
  "name": "tlingit-electron",
  "version": "1.0.0",
  "main": "main.js",
  "license": "MIT",
  "description": "Standalone Electron + Django app for Tlingit corpus exploration.",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.tlingit.app",
    "productName": "Tlingit App",
    "directories": {
      "output": "../dist_electron"
    },
    "files": [
      "**/*"
    ],


    "extraResources": [
      {
        "from": "../tlingit_app/dist/tlingit_backend",
        "to": "backend/arm64/tlingit_backend"
      },
      {
        "from": "../tlingit_app/dist_x86/tlingit_backend",
        "to": "backend/x64/tlingit_backend"
      },
      {
        "from": "../tlingit_app/dist/tlingit_backend.exe",
        "to": "backend/tlingit_backend.exe"
      }
    ],


    "mac": {
      "category": "public.app-category.education",
      "target": {
        "target": "dmg",
        "arch": ["universal"]
      },
      "identity": "",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "binaries": [
        "Contents/Resources/backend/arm64/tlingit_backend",
        "Contents/Resources/backend/x64/tlingit_backend"
      ],
      "x64ArchFiles": "**/*"

    },
    "afterAllArtifactBuild": "scripts/notarize.js",

    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12"
  }
}
